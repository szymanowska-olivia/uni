val fresh : 'a H.t -> int
type env = value M.t
and value =
    VInt of int
  | VBool of bool
  | VUnit
  | VPair of value * value
  | VClosure of string * Ast.expr * env
  | VRecClosure of string * string * Ast.expr * env
  | VRef of int
type heap = value Map.Make(Loc).t
val show_value : value -> string
module type COMP =
  sig
    type 'a comp
    val return : 'a -> 'a comp
    val bind : 'a comp -> ('a -> 'b comp) -> 'b comp
    val geth : heap comp
    val seth : heap -> unit comp
    val run : 'a comp -> 'a
  end
module Comp : COMP
val ( let* ) : 'a Comp.comp -> ('a -> 'b Comp.comp) -> 'b Comp.comp
val refc : value -> Loc.t Comp.comp
val derefc : Loc.t -> value Comp.comp
val assgn : Loc.t -> value -> unit Comp.comp
val int_op : (int -> int -> int) -> value -> value -> value Comp.comp
val cmp_op : (int -> int -> bool) -> value -> value -> value Comp.comp
val bool_op : (bool -> bool -> bool) -> value -> value -> value Comp.comp
val eval_op : Ast.bop -> value -> value -> value Comp.comp
val eval_env : env -> Ast.expr -> value Comp.comp
val eval : Ast.expr -> value
val interp : string -> value
